# Database (auto-injected by Railway)
DATABASE_URL=postgresql://user:password@localhost:5432/aiplatform

# Redis (auto-injected by Railway)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=                    # openssl rand -hex 64
ENCRYPTION_KEY=                # openssl rand -hex 32 (exactly 64 hex chars = 32 bytes)

# Super-admin bootstrap (delete after first run)
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=changeme123

# App
APP_URL=http://localhost:5173  # Production: https://yourapp.up.railway.app

# Meta (global for the app, not per-tenant)
META_APP_ID=                   # from Meta Developer Console
META_APP_SECRET=               # from Meta Developer Console
META_WEBHOOK_VERIFY_TOKEN=     # openssl rand -hex 16

NODE_ENV=development
PORT=3001
